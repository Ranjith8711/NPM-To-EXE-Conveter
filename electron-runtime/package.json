{
  "name": "app",
  "version": "1.0.0",
  "description": "Packaged by BEST TEAM NPM-to-EXE Converter",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist":  "electron-builder --win --x64"
  },
  "dependencies": {},
  "devDependencies": {
    "electron":         "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "productName": "App",
    "appId":       "com.besttean.app",
    "asar":        true,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "src/**",
      "preload/**",
      "webapp/**",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick":          false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
